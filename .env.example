# SecureDoc runtime mode
SECUREDOC_ENV=development
SECUREDOC_DATABASE_URL=sqlite:///./securedoc.db
# Dev-only: when true, startup syncs seeded demo user name/role/status into
# existing local DB rows. Keep false when managing users through Admin UI.
SECUREDOC_SYNC_SEEDED_USERS=false

# Dangerous compatibility endpoints. Keep disabled unless running a classroom
# demo that explicitly needs backend-generated/sent private keys.
ENABLE_LEGACY_DEMO=false

# Educational blind-signature token flow. Automatically disabled when
# SECUREDOC_ENV=production.
ENABLE_BLIND_SIGNATURE_DEMO=false

# Runtime-only demo CA/TSA/blind-signer keys. This path is git-ignored.
SECUREDOC_RUNTIME_SECRETS_DIR=.securedoc-runtime
SECUREDOC_DOCUMENT_STORAGE_DIR=.securedoc-runtime/documents
SECUREDOC_RFC3161_TSA_URL=

# Phase 1 API hardening
SECUREDOC_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECUREDOC_REQUEST_SIZE_LIMIT_BYTES=2097152
SECUREDOC_RATE_LIMIT_REQUESTS_PER_MINUTE=120
SECUREDOC_HTTPS_ONLY=false
SECUREDOC_JWT_SECRET=change-me-long-random-jwt-secret
SECUREDOC_JWT_TTL_SECONDS=3600
ENABLE_DEMO_HEADER_AUTH=false
SECUREDOC_OTP_PEPPER=change-me-long-random-otp-pepper
SECUREDOC_TOTP_ENCRYPTION_KEY=change-me-long-random-totp-encryption-secret

# Optional Email OTP delivery. If SMTP host is empty, OTPs are still hashed in
# the database but are not delivered or returned by the API.
# For classroom/local frontend testing without SMTP, set this to true and leave
# SECUREDOC_SMTP_HOST empty. Automatically ignored in production.
SECUREDOC_DEMO_OTP_IN_RESPONSE=false
SECUREDOC_SMTP_HOST=smtp.gmail.com
SECUREDOC_SMTP_PORT=587
SECUREDOC_SMTP_USERNAME=lucdoka1245@gmail.com
SECUREDOC_SMTP_PASSWORD=change-me-google-app-password
SECUREDOC_SMTP_FROM_EMAIL=lucdoka1245@gmail.com
SECUREDOC_SMTP_USE_TLS=true
